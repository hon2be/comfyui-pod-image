{
  "_meta": {
    "workflow_id": "style-transfer-preserve",
    "purpose": "Workflow A · 원본 인물·구도·포즈 유지 우선, 스타일 은은하게",
    "notes": "denoise 0.30 · IPAdapter style-transfer 0.55 · Depth ControlNet 1.0 (0~85%) · Canny 0.35 (0~60%). 얼굴은 낮은 denoise + Depth 로 유지. 스타일이 약하면 style_strength 를 0.7까지, 얼굴이 뭉개지면 denoise 를 0.20 까지 낮추세요.",
    "tunable_nodes": {
      "seed": "31",
      "style_strength": "21",
      "structure_depth_strength": "25",
      "structure_canny_strength": "28",
      "denoise": "31",
      "steps": "31",
      "cfg": "31",
      "positive_prompt": "13",
      "negative_prompt": "14",
      "content_image": "10",
      "style_image": "11"
    }
  },

  "3": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "juggernautXL_ragnarok.safetensors" },
    "_meta": { "title": "Checkpoint · Juggernaut XL (볼륨에 이미 있음)" }
  },

  "10": {
    "class_type": "LoadImage",
    "inputs": { "image": "content.png" },
    "_meta": { "title": "content · 보존 대상" }
  },
  "11": {
    "class_type": "LoadImage",
    "inputs": { "image": "style-reference.png" },
    "_meta": { "title": "style · 참조 화풍" }
  },

  "12": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["10", 0],
      "vae": ["3", 2]
    },
    "_meta": { "title": "content → latent" }
  },

  "13": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "masterpiece, best quality, keep the original subject identity, facial features, pose, camera angle, proportions, clothing structure, and object placement. Apply the visual style from the style reference: its brushwork, color palette, lighting mood, texture, line quality, and level of detail",
      "clip": ["3", 1]
    },
    "_meta": { "title": "Positive · 스타일 지시" }
  },
  "14": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "photograph, camera, film grain, watermark, text, logo, deformed, disfigured, extra limbs, blurry, low quality, jpeg artifacts, bad anatomy, extra fingers, mutated hands, ugly, oversaturated, plastic, uncanny valley",
      "clip": ["3", 1]
    },
    "_meta": { "title": "Negative" }
  },

  "20": {
    "class_type": "IPAdapterUnifiedLoader",
    "inputs": {
      "model": ["3", 0],
      "preset": "PLUS (high strength)"
    },
    "_meta": { "title": "IPAdapter Loader · SDXL PLUS" }
  },
  "21": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model": ["20", 0],
      "ipadapter": ["20", 1],
      "image": ["11", 0],
      "weight": 0.55,
      "weight_type": "style transfer",
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 0.85,
      "embeds_scaling": "V only"
    },
    "_meta": { "title": "IPAdapter · InstantStyle (style block only)" }
  },

  "23": {
    "class_type": "DepthAnythingV2Preprocessor",
    "inputs": {
      "image": ["10", 0],
      "ckpt_name": "depth_anything_v2_vitl.pth",
      "resolution": 1024
    },
    "_meta": { "title": "Depth 전처리" }
  },
  "24": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "controlnet-depth-sdxl-1.0.safetensors" },
    "_meta": { "title": "ControlNet · Depth" }
  },
  "25": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["13", 0],
      "negative": ["14", 0],
      "control_net": ["24", 0],
      "image": ["23", 0],
      "strength": 1.0,
      "start_percent": 0.0,
      "end_percent": 0.85
    },
    "_meta": { "title": "Depth 적용 · 구조 보존" }
  },

  "26": {
    "class_type": "CannyEdgePreprocessor",
    "inputs": {
      "image": ["10", 0],
      "low_threshold": 100,
      "high_threshold": 200,
      "resolution": 1024
    },
    "_meta": { "title": "Canny 전처리 · 경계" }
  },
  "27": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "controlnet-canny-sdxl-1.0.safetensors" },
    "_meta": { "title": "ControlNet · Canny" }
  },
  "28": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["25", 0],
      "negative": ["25", 1],
      "control_net": ["27", 0],
      "image": ["26", 0],
      "strength": 0.35,
      "start_percent": 0.0,
      "end_percent": 0.6
    },
    "_meta": { "title": "Canny 적용 · 오브젝트 경계" }
  },

  "31": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["21", 0],
      "positive": ["28", 0],
      "negative": ["28", 1],
      "latent_image": ["12", 0],
      "seed": 20260718,
      "steps": 28,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.30
    },
    "_meta": { "title": "KSampler · 보존 우선" }
  },
  "32": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["31", 0],
      "vae": ["3", 2]
    },
    "_meta": { "title": "VAE Decode" }
  },

  "40": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["32", 0],
      "filename_prefix": "style_preserve"
    },
    "_meta": { "title": "결과 저장 · style_preserve_*.png" }
  }
}
