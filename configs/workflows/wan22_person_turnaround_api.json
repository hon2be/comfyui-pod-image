{
  "_meta": {
    "workflow_id": "wan22-person-turnaround",
    "purpose": "WAN 2.2 Fun Camera · 인물 정면 사진 → 360° 회전 5초 영상 (Static 카메라 · 인물이 회전) · 정식 파이프라인 (ModelSamplingSD3 shift=8 + KSamplerAdvanced 2단계 · 20-step · CFG 3.5 · LoRA 없음)",
    "notes": "인물 identity 시트 캡처용 · 이 5초에서 30도 간격 12프레임 뽑으면 360° turnaround 시트 완성. 배경 프롬프트 강화 필수 (없으면 산업 스튜디오·구조물로 환각). LoRA + 4-step 옵션은 dynamics 손실 있음 (Note 참고).",
    "tunable_nodes": {
      "start_image": "10",
      "camera_pose": "12",
      "positive_prompt": "20",
      "negative_prompt": "21",
      "seed": "40",
      "width": "12",
      "height": "12",
      "length": "12"
    }
  },
  "1":  { "class_type": "UNETLoader", "inputs": { "unet_name": "wan2.2_fun_camera_high_noise_14B_fp8_scaled.safetensors", "weight_dtype": "default" } },
  "2":  { "class_type": "UNETLoader", "inputs": { "unet_name": "wan2.2_fun_camera_low_noise_14B_fp8_scaled.safetensors",  "weight_dtype": "default" } },
  "3":  { "class_type": "ModelSamplingSD3", "inputs": { "model": ["1", 0], "shift": 8.0 } },
  "4":  { "class_type": "ModelSamplingSD3", "inputs": { "model": ["2", 0], "shift": 8.0 } },
  "5":  { "class_type": "CLIPLoader", "inputs": { "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors", "type": "wan" } },
  "6":  { "class_type": "VAELoader", "inputs": { "vae_name": "wan_2.1_vae.safetensors" } },
  "7":  { "class_type": "CLIPVisionLoader", "inputs": { "clip_name": "ViT-H-14-laion2B-s32B-b79K.safetensors" } },

  "10": { "class_type": "LoadImage", "inputs": { "image": "hero_front.png" } },
  "11": { "class_type": "CLIPVisionEncode", "inputs": { "clip_vision": ["7", 0], "image": ["10", 0], "crop": "center" } },

  "12": { "class_type": "WanCameraEmbedding", "inputs": {
      "camera_pose": "Static", "width": 480, "height": 832, "length": 81, "speed": 1.0 } },

  "20": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["5", 0], "text":
      "A young Korean woman stays exactly in the center of a clean plain light gray seamless photography studio. She slowly rotates her body 360 degrees in place, keeping her feet planted, arms relaxed at sides. She starts facing the camera, turns to her left showing her side profile, then her back, then her other side, and returns to facing the camera. She wears the same white crew-neck t-shirt, high-waist mid-blue jeans and white sneakers throughout. Long jet-black high ponytail with heavy front bangs. Soft even studio lighting from the front. Photorealistic. Smooth continuous rotation." } },
  "21": { "class_type": "CLIPTextEncode", "inputs": { "clip": ["5", 0], "text":
      "色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，camera shake, background change, industrial, machinery, extra limbs, extra fingers, morphing, outfit change, hair change, blurry, distorted, deformed, jitter" } },

  "30": { "class_type": "WanCameraImageToVideo", "inputs": {
      "positive": ["20", 0], "negative": ["21", 0], "vae": ["6", 0],
      "width": 480, "height": 832, "length": 81, "batch_size": 1,
      "clip_vision_output": ["11", 0], "start_image": ["10", 0], "camera_conditions": ["12", 0] } },

  "40": { "class_type": "KSamplerAdvanced", "inputs": {
      "model": ["3", 0], "add_noise": "enable", "noise_seed": 42, "steps": 20, "cfg": 3.5,
      "sampler_name": "euler", "scheduler": "simple",
      "positive": ["30", 0], "negative": ["30", 1], "latent_image": ["30", 2],
      "start_at_step": 0, "end_at_step": 10, "return_with_leftover_noise": "enable" } },
  "41": { "class_type": "KSamplerAdvanced", "inputs": {
      "model": ["4", 0], "add_noise": "disable", "noise_seed": 0, "steps": 20, "cfg": 3.5,
      "sampler_name": "euler", "scheduler": "simple",
      "positive": ["30", 0], "negative": ["30", 1], "latent_image": ["40", 0],
      "start_at_step": 10, "end_at_step": 10000, "return_with_leftover_noise": "disable" } },

  "50": { "class_type": "VAEDecode", "inputs": { "samples": ["41", 0], "vae": ["6", 0] } },
  "60": { "class_type": "CreateVideo", "inputs": { "images": ["50", 0], "fps": 16.0, "bit_depth": 8 } },
  "70": { "class_type": "SaveVideo", "inputs": { "video": ["60", 0], "filename_prefix": "turnaround", "format": "mp4", "codec": "h264" } }
}
